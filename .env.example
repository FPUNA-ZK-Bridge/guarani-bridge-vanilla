## Docker Environment Variables
NODE_ENV=production

## Local Docker Networks (automatically configured by Docker Compose)
L1_RPC_URL=http://hardhat-n1:8545
L2_RPC_URL=http://anvil-n2:9545

## External Network RPC URLs (for production/testnet)
# RPC_URL_L1=wss://sepolia.infura.io/ws/v3/<YOUR_KEY>
# RPC_URL_L2=https://optimism-sepolia.infura.io/v3/<YOUR_KEY>

## Hardhat networks (deploy scripts)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<YOUR_KEY>
# SEPOLIA_PRIVATE_KEY=0x...
# SEPOLIA_CHAIN_ID=11155111

## Frontend monitoring RPCs (optional, avoids leaking API keys in bridge-config.json)
# BROWSER_RPC_URL_SEPOLIA=https://rpc.sepolia.org

## Custom network example (BlockDAG)
# BLOCKDAG_RPC_URL=https://<blockdag-rpc>
# BLOCKDAG_PRIVATE_KEY=0x...
# BLOCKDAG_CHAIN_ID=...
# BROWSER_RPC_URL_BLOCKDAG=https://<blockdag-rpc-public-or-proxy>

## Private Keys
PRIVATE_KEY_DEPLOYER=0xac0974bec39a17e36ba4a6b4d238ff944bacb476c6b8d6c1f02cb9433d8986625
PRIVATE_KEY_RELAYER=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

## Relayer Configuration
RELAYER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
START_BLOCK_L1=0

## Logging
LOG_LEVEL=info

## Contract Addresses (auto-populated after deployment)
# GUARANI_TOKEN_ADDRESS=
# SENDER_ADDRESS=
# RECEIVER_ADDRESS=
