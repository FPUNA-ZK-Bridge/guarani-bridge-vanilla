# ============================================
# BRIDGE_ENV: "local" o "testnet"
# Esta es la UNICA variable que necesitás cambiar.
# Todo lo demás se configura automáticamente.
# ============================================
BRIDGE_ENV=local

# ─── Variables para testnet (ignoradas en local) ───

# Ephemery (L1 testnet)
EPHEMERY_RPC_URL=http://localhost:8545
EPHEMERY_PRIVATE_KEY=<tu_private_key_sin_0x>
EPHEMERY_CHAIN_ID=39438156

# BlockDAG (L2 testnet)
BLOCKDAG_RPC_URL=https://rpc.awakening.bdagscan.com
BLOCKDAG_PRIVATE_KEY=<tu_private_key_sin_0x>
BLOCKDAG_CHAIN_ID=1043

# Relayer (testnet)
PRIVATE_KEY_DEPLOYER=0x...
PRIVATE_KEY_RELAYER=0x...
RELAYER_ADDRESS=0x...

# ─── Overrides opcionales (ambos entornos) ───

# Override RPCs del relayer (si no se definen, se usan los del preset)
# RPC_URL_N1=http://...
# RPC_URL_N2=http://...

# Gas overrides para N2
# N2_GAS_LIMIT=300000
# N2_GAS_PRICE_GWEI=10
# N2_MAX_FEE_GWEI=20
# N2_PRIORITY_FEE_GWEI=2
